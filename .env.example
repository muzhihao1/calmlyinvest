# Environment Configuration
NODE_ENV=development
PORT=3000

# Market Data Configuration
# Set to 'true' to use mock data instead of real Yahoo Finance data
USE_MOCK_DATA=false

# Database Configuration (Required for production)
# Supabase: Get from https://app.supabase.com/project/YOUR_PROJECT/settings/database
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

# Authentication Secret (Required for production)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Application URL (for CORS and redirects)
# Development: http://localhost:3001
# Production: https://your-domain.vercel.app
APP_URL=http://localhost:3001